# Kopiere diese Datei zu .env.local und trage die echten Werte ein.
# Die Werte kommen aus deinem eigenen Supabase-Projekt (Dashboard: Settings -> API);
# dort muss der Google-Provider aktiviert sein (Authentication -> Providers).
# NIE die echten Werte committen - .env.local ist gitignored.

# Supabase-Projekt-URL (Format: https://<projekt-ref>.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Supabase Publishable/Anon Key (Dashboard: Settings -> API Keys)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Nur E-Mails dieser Domain kommen durch das Gate
ALLOWED_EMAIL_DOMAIN=admkrs.com
